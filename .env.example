#  Daraja API 
#
# Get these from https://developer.safaricom.co.ke → My Apps
# Sandbox: use the auto-generated test credentials
# Production: create a separate app with production keys

# Sandbox:  https://sandbox.safaricom.co.ke
# Production: https://api.safaricom.co.ke
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke

# From Daraja portal → My Apps → {your app} → Keys & Credentials
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here

# Sandbox Paybill: 174379
# Production: your actual Paybill or Till number
DARAJA_SHORTCODE=174379

# Sandbox passkey (from Daraja portal → Test Credentials):
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Must be HTTPS and publicly accessible by Safaricom.
# Sandbox: use ngrok (docker compose --profile sandbox up → http://localhost:4040)
# Production: your real domain
DARAJA_CALLBACK_BASE_URL=https://xxxx.ngrok.io

# B2C credentials 
DARAJA_B2C_INITIATOR_NAME=testapi
DARAJA_B2C_SECURITY_CREDENTIAL=your_encrypted_credential

#  Database 
# Must use asyncpg driver: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://mpesa:mpesa_dev_password@localhost:5432/mpesa_db

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

# NEVER set to true in production — logs all SQL including sensitive data
DATABASE_ECHO=false

#  Redis 
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

#  Security 
# MUST be false in production — enables IP allowlist for Safaricom callbacks
TRUST_CALLBACK_IPS_IN_SANDBOX=true

#  Observability 
LOG_LEVEL=INFO
ENVIRONMENT=development
SERVICE_NAME=mpesa-stk-service

# Optional — set your Sentry DSN for error tracking
# SENTRY_DSN=https://xxxx@sentry.io/xxxx

#  ngrok (sandbox callback routing only) 
# Get a free token at https://dashboard.ngrok.com
# Required for: docker compose --profile sandbox up ngrok
NGROK_AUTHTOKEN=your_ngrok_token_here

#  Rate Limiting (tuning) 
# Daraja sandbox: ~30 req/min. Production: higher — confirm with Safaricom.
STK_RATE_LIMIT_CAPACITY=20
STK_RATE_LIMIT_REFILL_RATE=0.5

#  Circuit Breaker 
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
